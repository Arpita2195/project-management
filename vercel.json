{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://taskflow-backend-1-q8ya.onrender.com/api/$1" },
    { "source": "/socket.io/(.*)", "destination": "https://taskflow-backend-1-q8ya.onrender.com/socket.io/$1" },
    { "source": "/((?!assets/|favicon.ico|apple-touch-icon.png|mask-icon.svg|pwa-192x192.png|pwa-512x512.png|manifest.webmanifest|sw.js|workbox-.*).*)", "destination": "/index.html" }
  ]
}
