{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://project-management-sgrl.onrender.com/api/$1" },
    { "source": "/socket.io/(.*)", "destination": "https://project-management-sgrl.onrender.com/socket.io/$1" },
